<script>
(function() {
  'use strict';
  const search = document.getElementById('filter-search');
  const sevChips = document.querySelectorAll('[data-sev]');
  const kindChips = document.querySelectorAll('[data-kind]');
  const phases = document.querySelectorAll('details.phase');
  const noResults = document.getElementById('no-results');

  function activeFilters() {
    const sevs = new Set();
    sevChips.forEach(c => { if (c.classList.contains('active')) sevs.add(c.dataset.sev); });
    const kinds = new Set();
    kindChips.forEach(c => { if (c.classList.contains('active')) kinds.add(c.dataset.kind); });
    const q = (search.value || '').trim().toLowerCase();
    return { sevs, kinds, q };
  }

  function applyFilters() {
    const { sevs, kinds, q } = activeFilters();
    let totalVisible = 0;
    phases.forEach(phase => {
      const rows = phase.querySelectorAll('tr.finding');
      let visibleInPhase = 0;
      rows.forEach(row => {
        const matchSev = sevs.has(row.dataset.sev);
        const matchKind = kinds.has(row.dataset.kind);
        const matchSearch = !q || row.dataset.search.includes(q);
        const ok = matchSev && matchKind && matchSearch;
        row.style.display = ok ? '' : 'none';
        if (ok) visibleInPhase++;
      });
      // Hide entire phase block when no visible rows
      phase.style.display = visibleInPhase === 0 ? 'none' : '';
      totalVisible += visibleInPhase;
    });
    noResults.style.display = totalVisible === 0 ? '' : 'none';
  }

  // Chip toggling
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', e => {
      e.preventDefault();
      chip.classList.toggle('active');
      applyFilters();
    });
  });

  search.addEventListener('input', applyFilters);

  document.getElementById('filter-reset').addEventListener('click', () => {
    search.value = '';
    document.querySelectorAll('.chip').forEach(c => c.classList.add('active'));
    applyFilters();
  });

  document.getElementById('expand-all').addEventListener('click', () => {
    phases.forEach(p => p.open = true);
  });
  document.getElementById('collapse-all').addEventListener('click', () => {
    phases.forEach(p => p.open = false);
  });
  document.getElementById('expand-issues').addEventListener('click', () => {
    phases.forEach(p => {
      const hasHigh = p.querySelector('tr.finding[data-sev="HIGH"], tr.finding[data-sev="CRITICAL"]');
      p.open = !!hasHigh;
    });
  });

  applyFilters();
})();
</script>
</body>
